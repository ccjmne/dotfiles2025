" vim:tw=80:sw=4:et:sta
vim9script

syntax          on
filetype indent on
filetype plugin on

packadd comment
packadd hlyank | g:hlput_enable = true | g:hlyank_duration = 100 | g:hlput_duration = 100

v:clipproviders['wl'] = {
    copy:  {'+': (_, __, lines) => system('wl-copy', lines)},
    paste: {'+': (_) => ['', systemlist('wl-paste')]},
}

se clipmethod^=wl clipboard=unnamed
se cul nu rnu
se hidden
se ignorecase smartcase incsearch hlsearch
se list listchars=tab:»\ ,trail:·,nbsp:␣,precedes:<,extends:>
se mouse=a ttymouse=sgr                  # tmux-ready (SGR) mouse in [a]ll modes
se nf=bin,hex
se scrolloff=8 sidescrolloff=8 nowrap
se spelllang=en_gb
se splitright splitbelow fillchars=vert:\ 
se t_Co=16                       # force 16 colours, :help terminal-output-codes
se timeoutlen=320 ttimeoutlen=0
se undofile undodir=$XDG_CACHE_HOME/vim/undo
se wildoptions=pum

if executable('rg') | se grepprg=rg\ --vimgrep | endif

# -------------------------------- HIGHLIGHTS ----------------------------------
hi ColorColumn                 ctermbg=0     cterm=reverse
hi CursorColumn                ctermbg=NONE  cterm=reverse
hi CursorLine                                cterm=bold,underline
hi CursorLineNR  ctermfg=NONE
hi LineNR        ctermfg=8
hi Visual        ctermfg=NONE  ctermbg=NONE  cterm=bold,reverse
hi Search        ctermfg=NONE  ctermbg=NONE  cterm=bold,reverse
hi Todo          ctermfg=3     ctermbg=NONE  cterm=bold,reverse
hi Error         ctermfg=1     ctermbg=NONE  cterm=bold,reverse
hi ErrorMsg      ctermfg=1     ctermbg=NONE
hi MoreMsg       ctermfg=6
hi Question      ctermfg=6
hi SignColumn    ctermfg=NONE  ctermbg=NONE

#---------------------------------- BINDINGS -----------------------------------
g:mapleader = ' '
nno <Leader>ve :exe &l:ve == 'all' ? 'setl ve< cuc<' : 'setl ve=all cuc'

nno <Leader>x :
nno         :nohl:lcl:ccl:pc
nno       mz:tabe %`zzz

nno j :cnext
nno k :cprev
nno h :cold
nno l :cnew

#                    FZF BINDINGS ..............................................
nno <Leader>-        :History!
nno <Leader><Leader> :Buffers!
nno <Leader>f,       :Files! ~/git/dotfiles
nno <Leader>ff       :Files!
nno <Leader>fg       :Rg!
nno <Leader>fh       :Helptags!

#                    CMD BINDINGS ..............................................
cno j <Down>
cno k <Up>

# ------------------------------ LOCAL HELPERS ---------------------------------
au BufEnter    kr100 norm! G
au InsertLeave kr100 norm! ^"=strftime("%F  ")Pw"ayiwE"byiw$"=printf("  %.1f", 100/(a+b/60.0))p
