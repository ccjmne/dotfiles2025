// vim: set ft=jsonc
{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "keybinds": {
    "messages_next": "meta+j",
    "messages_previous": "meta+k"
  },
  "provider": {
    "langdock-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.langdock.com/openai/eu/v1/"
      },
      "models": {
        "gpt-4.1": {
          "name": "gpt-4.1"
        },
        "gpt-4.1-mini": {
          "name": "gpt-4.1-mini"
        },
        "gpt-4.1-nano": {
          "name": "gpt-4.1-nano"
        },
        "gpt-4o": {
          "name": "gpt-4o"
        },
        "gpt-4o-mini": {
          "name": "gpt-4o-mini"
        },
        "gpt-5": {
          "name": "gpt-5"
        },
        "gpt-5-chat": {
          "name": "gpt-5-chat"
        },
        "gpt-5-mini": {
          "name": "gpt-5-mini"
        },
        "gpt-5-nano": {
          "name": "gpt-5-nano"
        },
        "o1": {
          "name": "o1"
        },
        "o1-mini": {
          "name": "o1-mini"
        },
        "o1-preview": {
          "name": "o1-preview"
        },
        "o3": {
          "name": "o3"
        },
        "o3-mini": {
          "name": "o3-mini"
        },
        "o4-mini": {
          "name": "o4-mini"
        }
      }
    },
    "langdock-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.langdock.com/anthropic/eu/v1/"
      },
      // curl https://api.langdock.com/anthropic/eu/v1/models -H "Authorization: Bearer $LANGDOCK_API_KEY" | jq '.data | map({ (.id): { name:.id } }) | add'
      "models": {
        "claude-sonnet-4-6-default": {
          "name": "claude-sonnet-4-6-default"
        },
        "claude-sonnet-4-5-20250929": {
          "name": "claude-sonnet-4-5-20250929"
        },
        "claude-opus-4-6-default": {
          "name": "claude-opus-4-6-default"
        },
        "claude-haiku-4-5-20251001": {
          "name": "claude-haiku-4-5-20251001"
        },
        "claude-opus-4-5-20251101": {
          "name": "claude-opus-4-5-20251101"
        }
      }
    },
    "langdock-mistral": {
      "npm": "@ai-sdk/mistral",
      "options": {
        "baseURL": "https://api.langdock.com/mistral/eu/v1/"
      },
      "models": {
        "codestral-2501": {
          "name": "codestral-2501"
        }
      }
    }
  }
}
