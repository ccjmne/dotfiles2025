# vim: ft=dosini

# Behaviour
layer=overlay
output=eDP-1
on-notify=exec paplay ~/config/theme/beep.ogg
on-button-middle=exec makoctl menu -n$id fuzzel -- --dmenu --anchor=top-right --hide-prompt

# Appearance
border-size=1
padding=5,15
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#6c7086
progress-color=over #313244

