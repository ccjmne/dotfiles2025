export CARGO_HOME="$XDG_DATA_HOME/cargo"
export LUAROCKS_HOME="$XDG_DATA_HOME/luarocks"
export PNPM_HOME="$XDG_DATA_HOME/pnpm"

typeset -U cdpath; cdpath=("$HOME/git" "$HOME/git.unite" "$HOME/git.skynet")
typeset -U  fpath;  fpath=("${fpath[@]}" "$XDG_DATA_HOME/zsh/site-functions")
typeset -U   path;   path=("$HOME/bin" "${path[@]}" "$XDG_DATA_HOME/nvim/mason/bin")
[[ -d "$CARGO_HOME/bin" ]]    && path+="$CARGO_HOME/bin"
[[ -d "$PNPM_HOME" ]]         && path+="$PNPM_HOME"
[[ -d "$LUAROCKS_HOME/bin" ]] && path+="$LUAROCKS_HOME/bin"

(( $+commands[nvim] ))                 && export EDITOR=nvim VISUAL=nvim MANPAGER='nvim +Man!'
(( $+commands[ghostty] ))              && export TERMINAL=ghostty              # For fuzzel to handle Terminal=true \.desktop entries, for instance
(( $+commands[google-chrome-stable] )) && export BROWSER=google-chrome-stable  # Just in case something might use it (like man --html)

export BAT_STYLE=plain
export BAT_THEME=base16
export CALCHISTFILE="$XDG_STATE_HOME/calc/history"
export CALCPATH=".:$XDG_DATA_HOME/calc:$XDG_CONFIG_HOME/calc:/usr/share/calc:/usr/share/calc/custom"
export CALCRC="$XDG_CONFIG_HOME/calc/calcrc"
export FCEDIT="$EDITOR +'se ft=sh'"
export FZF_CTRL_T_COMMAND='rg --files 2> /dev/null' # Ctrl-T searches only visible files
export FZF_DEFAULT_COMMAND='rg --files --hidden'    # Search hidden files w/ fzf
export FZF_DEFAULT_OPTS_FILE=/home/ccjmne/git/dotfiles/home/config/fzf/opts
export GNUPGHOME="$XDG_CONFIG_HOME/gnupg"
export LUA_CPATH="$LUAROCKS_HOME/lib/lua/5.4/?.so;;"
export LUA_PATH="$LUAROCKS_HOME/share/lua/5.4/?.lua;$LUAROCKS_HOME/share/lua/5.4/?/init.lua;;"
export MANOPT='--no-justification --no-hyphenation'
export MANWIDTH=100
export MISE_CONFIG_FILE="$XDG_CONFIG_HOME/mise/config.toml"
export PARINIT="rTbgqR B=.,?'_A_a_@ Q=_s>|"
export WORDCHARS='*?_-.[]~=&;!#$%^(){}<>'   # dropped "/" from there, to Ctrl-W only last path segment
export ZLE_SPACE_SUFFIX_CHARS=$'&|'         # Avoid 'consuming' the space before a pipe or ampersand
export ZSH_CACHE_DIR="$XDG_CACHE_HOME/zsh"  # Supposedly omz-only but others (like mise) appear to use it too

eval $(dircolors)
