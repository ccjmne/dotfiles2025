[advice]
    statushints = 0
[checkout]
    defaultremote = upstream
[clone]
    defaultremotename = upstream
[commit]
    gpgsign = yes
    verbose = yes
[core]
    editor = vim +'norm $'
    fsmonitor = yes
    pager = less -SFX -x2
    untrackedcache = yes
[diff]
    algorithm = histogram
    colormoved = zebra
    mnemonicprefix = yes
    tool = vimdiff
[gpg]
    program = gpg2
[grep]
    column = yes
    linenumber = yes
[init]
    defaultbranch = master
    templatedir = ~/config/git/template
[merge]
    conflictstyle = zdiff3
    tool = vimdiff
[push]
    default = upstream
[rebase]
    autosquash = yes
    autostash = yes
[rerere]
    enabled = yes
[sendemail]
    smtpEncryption = tls
    smtpServer = smtp.gmail.com
    smtpServerPort = 587
    smtpUser = ccjmne@gmail.com
[status]
    aheadbehind = yes
    short = yes
[tag]
    gpgsign = yes
[url "git@gitlab.build-unite.unite.eu:"]
    insteadof = glue:
[url "git@github.com:"]
    insteadof = gh:
