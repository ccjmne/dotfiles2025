#! /bin/sh -e

if [ ! -d .git ]; then
    git clone --depth=1 --single-branch --branch=master --no-tags --origin=upstream \
        https://github.com/vim/vim.git .
fi

if [ "$1" = "uninstall" ]; then
    if [ ! -f src/auto/config.mk ]; then
        echo 'No configured Vim build to uninstall.' >&2
        exit 1
    fi
    make uninstall
    exit
fi

readonly key=4F19708816918E19AAE19DEEF3F92DA383FDDE09 # Christian Brabandt (@chrisbra) <cb@256bit.org>
tag=$(git ls-remote --refs --tags --sort=-version:refname upstream 'v*.[0-9][0-9][0-9][0-9]' | head -n1)
tag=${tag#*refs/tags/}
export GNUPGHOME=$(mktemp -d)
trap 'rm -rf -- "$GNUPGHOME"' EXIT
gpg --batch --keyserver hkps://keys.openpgp.org --recv-key $key
git fetch --depth=1 upstream tag "$tag"
git verify-tag "$tag"
git reset --hard "$tag"

make distclean && ./configure                                    \
    --prefix="$HOME"                                             \
    --disable-arabic                                             \
    --disable-canberra                                           \
    --disable-darwin                                             \
    --disable-netbeans                                           \
    --disable-nls                                                \
    --disable-rightleft                                          \
    --disable-selinux                                            \
    --disable-smack                                              \
    --disable-sysmouse                                           \
    --disable-xsmp                                               \
    --disable-xsmp-interact                                      \
    --enable-autoservername                                      \
    --enable-cscope                                              \
    --enable-fail-if-missing                                     \
    --enable-gpm=dynamic                                         \
    --enable-gui=no                                              \
    --enable-luainterp=dyn                                       \
    --enable-multibyte                                           \
    --enable-perlinterp=dyn                                      \
    --enable-python3interp=dyn                                   \
    --enable-rubyinterp=dyn                                      \
    --enable-tclinterp=dyn                                       \
    --enable-terminal                                            \
    --enable-year2038                                            \
    --with-compiledby='Éric NICOLAS (ccjmne) <ccjmne@gmail.com>' \
    --with-global-runtime=/usr/share/vim/vimfiles                \
    --with-luajit                                                \
    --with-wayland                                               \
    --without-gnome                                              \
    --without-x

make -j8
make install
