#! /bin/sh -e

readonly dir=$XDG_CACHE_HOME/${0##*/}
if [ ! -d "$dir/.git" ]; then
    git clone --depth=1 --single-branch --branch=master --no-tags \
        https://github.com/vim/vim.git "$dir"
fi
cd "$dir"
git fetch --depth=1 --no-tags upstream master
git reset --hard FETCH_HEAD

if ! head -n1 README.txt 2>/dev/null |
    grep -q '^README.txt for version [[:digit:]].[[:digit:]] of Vim: Vi IMproved.$'
then
    echo >&2 'Invalid Vim checkout.'
    exit 2
fi

./configure                                                      \
    --disable-arabic                                             \
    --disable-canberra                                           \
    --disable-darwin                                             \
    --disable-netbeans                                           \
    --disable-nls                                                \
    --disable-rightleft                                          \
    --disable-selinux                                            \
    --disable-smack                                              \
    --disable-sysmouse                                           \
    --disable-xsmp                                               \
    --disable-xsmp-interact                                      \
    --enable-autoservername                                      \
    --enable-cscope                                              \
    --enable-fail-if-missing                                     \
    --enable-gpm=dynamic                                         \
    --enable-gui=no                                              \
    --enable-luainterp=dyn                                       \
    --enable-multibyte                                           \
    --enable-perlinterp=dyn                                      \
    --enable-python3interp=dyn                                   \
    --enable-rubyinterp=dyn                                      \
    --enable-tclinterp=dyn                                       \
    --enable-terminal                                            \
    --enable-year2038                                            \
    --with-compiledby='Éric NICOLAS (ccjmne) <ccjmne@gmail.com>' \
    --with-global-runtime=/usr/share/vim/vimfiles                \
    --with-luajit                                                \
    --with-wayland                                               \
    --without-gnome                                              \
    --without-x

if [ "$1" = "uninstall" ]; then
    sudo make uninstall
else
    make -j8
    sudo make install
fi
