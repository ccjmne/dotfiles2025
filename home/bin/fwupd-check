#! /bin/sh

fwupdmgr refresh     --assume-yes
fwupdmgr get-updates --assume-yes
rc=$?

if [ $rc -eq 0 ]; then
    notify-send 'Firmware update check' 'Some updates are available' \
        --action='default=Run: fwupdmgr update'                      \
        | ifne ghostty -e ack fwupdmgr update
elif [ $rc -eq 2 ]; then
    notify-send 'Firmware update check' 'No updates available'
else
    exit $rc
fi
