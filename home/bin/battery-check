#! /bin/sh

readonly threshold=20
readonly bat=/sys/class/power_supply/BAT0
readonly lock="$XDG_RUNTIME_DIR/${0##*/}.lock"

notify() {
	cap=$1
	status=$2
	id=$3
	if [ -n "$id" ]; then
		replace=--replace-id=$id
		category=--hint=STRING:category:update
	else
		wait=--wait
	fi
	if [ "$cap" -le "$threshold" ]; then
		title='Battery low'
		urgency=--urgency=critical
	else
		title='Battery status'
		urgency=--urgency=normal
	fi
	notify-send "$title" "$status, currently at $cap%" \
		$urgency --hint="INT:value:$cap"           \
		--print-id $replace $category $wait
}

monitor() {
	cur=$(cat $bat/capacity)
	status=$(cat $bat/status)
	id=$1
	while true; do
		cur=$(cat $bat/capacity)
		status=$(cat $bat/status)
		id=$(notify $cur $status $id)
		sleep 10
	done
}

exec 9<> $lock
if flock --nonblock 9; then
	cur=$(cat $bat/capacity)
	status=$(cat $bat/status)
	if [ "$status" = "Discharging" ] && [ "$cur" -le "$threshold" ]; then
		notify $cur $status > $lock &
		pid=$!
		sleep .1
		monitor $(cat $lock) &
		upid=$!
		wait $pid
		kill $upid 2>/dev/null || true
	fi
fi
