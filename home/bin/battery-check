#! /bin/sh -e

readonly threshold=20
readonly bat=/sys/class/power_supply/${1-BAT0}
readonly lock=$XDG_RUNTIME_DIR/${0##*/}.lock
readonly fifo=$XDG_RUNTIME_DIR/${0##*/}.fifo

notify() {
	cur=$1; status=$2; id=$3
	if [ -n "$id" ]
	then persistence="--replace-id=$id --hint=STRING:category:update"
	else persistence='--wait --print-id'
	fi
	if [ $cur -le $threshold ]
	then title='Battery low';    urgency=critical
	else title='Battery status'; urgency=normal
	fi
	notify-send "$title" "$status, currently at $cur%" \
		--hint=INT:value:$cur --urgency=$urgency $persistence
}

exec 9> $lock && flock -n 9
cur=$(cat $bat/capacity)
status=$(cat $bat/status)
if [ $cur -le $threshold ]; then
	rm -f "$fifo" && mkfifo $fifo
	notify $cur "$status" > $fifo &
	notif=$!
	read id < $fifo
	while :; do
		sleep 10
		notify $(cat $bat/capacity) "$(cat $bat/status)" $id
	done &
	trap "kill $!" EXIT
	wait $notif
fi
