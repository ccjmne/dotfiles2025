#! /bin/sh

[ $# -eq 0 ] && echo >&2 "Usage: ${0##*/} <TASK ID> [--] [COMMAND...]" && exit 1

readonly id=$(printf %s "$1" | tr -cs A-Za-z0-9 -)
shift; [ "$1" = -- ] && shift

readonly lock=$XDG_RUNTIME_DIR/${0##*/}+${id}.lock
exec 9<> $lock
if flock --nonblock 9; then
	"$@" &
	readonly pid=$!
	echo $pid >&9
	wait $pid
	rm -- $lock
else
	kill $(cat $lock)
fi
